              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<soapenv:Envelope xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\" xmlns:lib=\"http://soap.library.smartcampus.com/\">\n  <soapenv:Header/>\n  <soapenv:Body>\n    <lib:reserveRoom>\n      <roomId>R103</roomId>\n      <studentId>S2001</studentId>\n      <bookingDate>2026-07-02</bookingDate>\n      <timeSlot>09:00 - 11:00</timeSlot>\n    </lib:reserveRoom>\n  </soapenv:Body>\n</soapenv:Envelope>"
            },
            "url": "http://localhost:8088/ws/library"
