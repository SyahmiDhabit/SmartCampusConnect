    {
      "name": "4. SOAP Legacy Service (8088)",
      "item": [
        {
          "name": "SOAP bookLoan Success B105",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"SOAP Response is correct XML and contains bookLoanResponse\", function () {",
                  "    pm.expect(pm.response.text()).to.include(\"bookLoanResponse\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "text/xml" }],
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<soapenv:Envelope xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\" xmlns:lib=\"http://soap.library.smartcampus.com/\">\n  <soapenv:Header/>\n  <soapenv:Body>\n    <lib:bookLoan>\n      <bookId>B105</bookId>\n      <studentId>S2001</studentId>\n    </lib:bookLoan>\n  </soapenv:Body>\n</soapenv:Envelope>"
            },
            "url": "http://localhost:8088/ws/library"
          }
        },
        {
          "name": "SOAP bookLoan Fault (Double B105)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 500 (SOAP Fault)\", function () {",
                  "    pm.response.to.have.status(500);",
                  "});",
                  "pm.test(\"SOAP Fault verification\", function () {",
                  "    pm.expect(pm.response.text()).to.include(\"Fault\");",
                  "    pm.expect(pm.response.text()).to.include(\"BookAlreadyLoanedFault\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "text/xml" }],
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<soapenv:Envelope xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\" xmlns:lib=\"http://soap.library.smartcampus.com/\">\n  <soapenv:Header/>\n  <soapenv:Body>\n    <lib:bookLoan>\n      <bookId>B105</bookId>\n      <studentId>S2001</studentId>\n    </lib:bookLoan>\n  </soapenv:Body>\n</soapenv:Envelope>"
            },
            "url": "http://localhost:8088/ws/library"
          }
